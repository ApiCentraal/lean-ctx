      </tr>
    </thead>
    <tbody>
      <tr>
        <td><code>ctx_read</code></td>
        <td>File reads (6 modes + optional <code>lines:N-M</code>: full, map, signatures, diff, aggressive, entropy)</td>
        <td>up to 99%</td>
      </tr>
      <tr>
        <td><code>ctx_tree</code></td>
        <td>Directory listings (ls, find, Glob)</td>
        <td>~40%</td>
      </tr>
      <tr>
        <td><code>ctx_shell</code></td>
        <td>Shell commands (90+ patterns)</td>
        <td>60-90%</td>
      </tr>
      <tr>
