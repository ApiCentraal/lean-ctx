---
import BaseLayout from '../layouts/BaseLayout.astro';

const categories = [
  {
    id: 'core',
    label: 'Core Tools',
    accent: 'green',
    description: 'The foundation. These four tools handle file reading, directory exploration, command execution, and code search.',
    tools: [
      {
        id: 'ctx_read',
        name: 'ctx_read',
        tagline: 'Smart File Read with 6 Modes',
        savings: 'up to 99%',
        description: 'Session-aware caching means files are only transmitted once. Re-reads return a 13-token cache hit. Six core modes plus optional line ranges (lines:N-M) let you choose exactly how much context the LLM receives.',
        modes: [
          { name: 'full', desc: 'Default. Structured headers + caching. Re-reads cost 13 tokens.', savings: '~99% re-read' },
          { name: 'map', desc: 'Dependency graph + exports + API signatures.', savings: '85-95%' },
          { name: 'signatures', desc: 'Tree-sitter AST extraction. 14 languages (TS/JS, Rust, Python, Go, Java, C, C++, Ruby, C#, Kotlin, Swift, PHP).', savings: '83-96%' },
          { name: 'diff', desc: 'Only changed lines since last read.', savings: '70-95%' },
          { name: 'aggressive', desc: 'Full content, stripped comments & whitespace.', savings: '20-40%' },
          { name: 'entropy', desc: 'Shannon entropy filtering + Jaccard dedup.', savings: '60-85%' },
        ],
        example: {
          input: 'ctx_read auth.ts --mode map',
          output: `F1=auth.ts [123L]
  deps: db, crypto, session
  exports: createUser, authenticateUser, validateSession
  API:
    fn async createUser(email:s, password:s) → User
    fn async authenticateUser(email:s, password:s) → Session
    fn async validateSession(token:s) → boolean
[794 tok saved (93%)]`,
        },
      },
      {
        id: 'ctx_multi_read',
        name: 'ctx_multi_read',
        tagline: 'Batch File Reads',
        savings: 'Fewer round-trips',
        description: 'Reads multiple paths in one tool call with the same modes and cache semantics as ctx_read. Ideal when the model needs several related files at once.',
        example: {
          input: 'ctx_multi_read paths=["src/auth.ts","src/db.ts"] --mode map',
          output: `F1=auth.ts [88L]
  deps: db, crypto, session
  exports: createUser, authenticateUser
F2=db.ts [64L]
  deps: pg
  exports: query, migrate
[2 files, 1820 tok saved vs full reads]`,
        },
      },
      {
        id: 'ctx_tree',
        name: 'ctx_tree',
        tagline: 'Compact Project Structure',
        savings: '34-60%',
        description: 'Token-efficient directory listings using indentation. Shows file counts per directory so the LLM understands project scale.',
        example: {
          input: 'ctx_tree --depth 2',
          output: `src/ (45)
  core/ (8)
  tools/ (5)
  dashboard/ (2)
  patterns/ (5)
package.json
README.md
[64 tok saved (34%)]`,
        },
      },
      {
        id: 'ctx_shell',
        name: 'ctx_shell',
        tagline: 'CLI Output Compression',
        savings: '60-90%',
        description: '90+ compression patterns across 34 categories: git, npm, cargo, docker, kubectl, gh, pip, ruff, rubocop, eslint, tsc, curl, vitest, terraform, make, maven, dotnet, flutter, poetry, aws, psql, mysql, prisma, helm, bun, deno, swift, zig, cmake, ansible, composer, mix, bazel, systemd, and more.',
        example: {
          input: 'ctx_shell "git status"',
          output: `feature/auth ↑3
staged: +session.ts ~login.ts ~api.ts
unstaged: ~session.ts
untracked: session.test.ts
[534 tok saved (87%)]`,
        },
      },
      {
        id: 'ctx_search',
        name: 'ctx_search',
        tagline: 'Token-efficient Code Search',
        savings: '50-80%',
        description: 'Pattern search that returns only matching lines with compact context. No need to read entire files.',
        example: {
          input: 'ctx_search "createUser" --ext ts',
          output: `3 matches in 2 files:
auth.ts:18 fn createUser(email:s, password:s, ...)
routes.ts:45 await createUser(body.email, body.pwd, ...)
routes.ts:89 // createUser validation
[~1200 tok saved vs full reads]`,
        },
      },
    ],
  },
  {
    id: 'optimization',
    label: 'Optimization & Analysis',
    accent: 'indigo',
    description: 'Deep analysis, benchmarking, context checkpoints, and cache control for power users.',
    tools: [
      {
        id: 'ctx_compress',
        name: 'ctx_compress',
        tagline: 'Context Checkpoint',
        savings: '90-95%',
        description: 'Compresses all cached files into an ultra-compact signature map. Use as a memory checkpoint for long conversations or fresh chats.',
        example: {
          input: 'ctx_compress',
          output: `CTX CHECKPOINT (12 files)

F1 auth.ts [123L]: fn generateToken, fn createUser, ...
F2 db.ts [89L]: cl Database, fn query, fn migrate
F3 routes.ts [234L]: fn setupRoutes, fn authMiddleware

COMPRESSION: 28450 -> 890 tok (97% saved)`,
        },
      },
      {
        id: 'ctx_benchmark',
        name: 'ctx_benchmark',
        tagline: 'Real Project Benchmarks',
        savings: 'Data-driven',
        description: 'Single-file or project-wide benchmark with real token measurements, latency tracking, and AST-based preservation scores. Supports terminal, markdown, and JSON output.',
        example: {
          input: 'ctx_benchmark path=. action=project',
          output: `Scanned: 42 files (12 ts, 8 rs, 6 py)
Total raw tokens: 145.2K

Mode         Tokens  Savings  Quality
map            7.5K    98.5%   93.4%
signatures     9.3K    98.2%   96.3%
aggressive   130.1K    10.4%  100.0%
cache_hit       546    99.6%     N/A`,
        },
      },
      {
        id: 'ctx_analyze',
        name: 'ctx_analyze',
        tagline: 'Information-Theoretic Analysis',
        savings: 'Diagnostic',
        description: 'Shannon entropy and Jaccard similarity analysis. Shows which lines carry information vs. boilerplate and recommends the optimal mode.',
        example: {
          input: 'ctx_analyze middleware.ts',
          output: `ANALYSIS: middleware.ts (78L, 1856 tok)

Entropy: H̄=3.2 bits/char (σ=1.1)
  Low-entropy (H<2.0): 14 lines (18%)
  High-entropy (H>4.0): 22 lines (28%)

Dedup potential: ~240 tokens (3 blocks)

Recommendation: entropy (-84%)`,
        },
      },
      {
        id: 'ctx_cache',
        name: 'ctx_cache',
        tagline: 'Session Cache Management',
        savings: 'Safety net',
        description: 'View, clear, or invalidate cached files. Essential for subagent workflows and after context compaction. Auto-clears after 5 min inactivity.',
        example: {
          input: 'ctx_cache action=status',
          output: `Cache: 3 file(s)
  F1=auth.ts [123L, 915t, read 4x]
  F2=db.ts [89L, 678t, read 2x]
  F3=routes.ts [234L, 1856t, read 1x]`,
        },
      },
    ],
  },
  {
    id: 'intelligence',
    label: 'Intelligence Engine',
    accent: 'amber',
    description: 'Adaptive mode selection, incremental deltas, intent detection, cross-file deduplication, and a project intelligence graph.',
    tools: [
      {
        id: 'ctx_smart_read',
        name: 'ctx_smart_read',
        tagline: 'Adaptive Mode Selection',
        savings: 'Automatic',
        description: 'Automatically picks the optimal compression mode based on file type, size, cache state, and token count. No manual mode selection needed.',
        example: {
          input: 'ctx_smart_read path=auth.ts',
          output: `auto-selected: diff (file cached, 3 lines changed)
+42: const maxRetries = 5;
+43: if (attempts > maxRetries) throw new Error("too many retries");
-42: const maxRetries = 3;

∂ +2/-1 lines`,
        },
      },
      {
        id: 'ctx_delta',
        name: 'ctx_delta',
        tagline: 'Incremental File Updates',
        savings: '80-95%',
        description: 'Sends only changed hunks via Myers diff instead of retransmitting the full file. Automatically updates the session cache.',
        example: {
          input: 'ctx_delta path=server.rs',
          output: `∂ server.rs (3 hunks)
@@ -42,3 +42,4 @@
+    let timeout = Duration::from_secs(30);
@@ -89,2 +90,2 @@
-    println!("starting");
+    info!("server started on {}", addr);

∂ +2/-1 lines | cache updated`,
        },
      },
      {
        id: 'ctx_dedup',
        name: 'ctx_dedup',
        tagline: 'Cross-File Deduplication',
        savings: 'Diagnostic',
        description: 'Scans all cached files for duplicate imports and identical code blocks. Reports potential token savings from deduplication.',
        example: {
          input: 'ctx_dedup',
          output: `DEDUP ANALYSIS (8 cached files)
Shared imports: 12 (est. 180 tok)
Identical blocks (5+ lines): 3 (est. 95 tok)

Top duplicates:
  use serde::{Serialize, Deserialize};  → 5 files
  use std::collections::HashMap;         → 4 files

Potential savings: ~275 tokens`,
        },
      },
      {
        id: 'ctx_fill',
        name: 'ctx_fill',
        tagline: 'Token Budget Optimizer',
        savings: 'Budget-aware',
        description: 'Given a list of files and a token budget, ranks files by relevance and selects the optimal compression mode for each to maximize information density.',
        example: {
          input: 'ctx_fill paths=["auth.ts","db.ts","routes.ts"] budget=500',
          output: `CONTEXT FILL (budget: 500 tok)
  auth.ts    → full   (210 tok) ★ priority
  db.ts      → map    (85 tok)
  routes.ts  → signatures (120 tok)

Total: 415/500 tok used (83%)
3 files included`,
        },
      },
      {
        id: 'ctx_intent',
        name: 'ctx_intent',
        tagline: 'Semantic Intent Detection',
        savings: 'Context-aware',
        description: 'Classifies natural language queries into intents (fix, add, refactor, understand, test, config, deploy) and auto-loads relevant files with optimal compression.',
        example: {
          input: 'ctx_intent query="fix the auth timeout bug"',
          output: `INTENT: FixBug (confidence: high)
Areas: auth, timeout, error-handling

Auto-loaded context:
  auth.ts        → full (will edit)
  session.ts     → map (dependency)
  auth.test.ts   → signatures (test surface)

Strategy: 3 files, ~450 tokens`,
        },
      },
      {
        id: 'ctx_response',
        name: 'ctx_response',
        tagline: 'Response Compression',
        savings: '10-30%',
        description: 'Compresses LLM-generated text by removing filler phrases and applying Token Dense Dialect shortcuts. Works on any text content.',
        example: {
          input: 'ctx_response text="The function returns a string value..."',
          output: `fn ret str val...
(compressed: 42 → 18 tok, -57%)`,
        },
      },
      {
        id: 'ctx_context',
        name: 'ctx_context',
        tagline: 'Multi-Turn Session Manager',
        savings: 'Awareness',
        description: 'Shows what the LLM already knows: cached files, read counts, and session state. Prevents redundant file re-reads in multi-turn conversations.',
        example: {
          input: 'ctx_context',
          output: `SESSION STATUS
Cached: 5 files | Reads: 23 | Hits: 18

Known files:
  F1=auth.ts (read 4x, last: full)
  F2=db.ts (read 2x, last: map)
  F3=routes.ts (read 1x, last: signatures)`,
        },
      },
      {
        id: 'ctx_graph',
        name: 'ctx_graph',
        tagline: 'Project Intelligence Graph',
        savings: 'Structural',
        description: 'Builds a dependency graph of your project. Finds related files, import chains, and exported symbols. Use "build" to scan and "related" to query.',
        example: {
          input: 'ctx_graph action=related path=auth.ts',
          output: `RELATED to auth.ts
Imports → db.ts, crypto.ts, session.ts
Imported by ← routes.ts, middleware.ts
Shared deps: config.ts (via db.ts, session.ts)

5 related files found`,
        },
      },
      {
        id: 'ctx_discover',
        name: 'ctx_discover',
        tagline: 'Shell History Analyzer',
        savings: 'Discovery',
        description: 'Scans your shell history to find commands that could have been compressed by lean-ctx. Estimates potential token and cost savings.',
        example: {
          input: 'ctx_discover',
          output: `MISSED OPTIMIZATIONS (last 500 commands)
  aws ec2 describe-instances    12x  est. ~4800 tok
  kubectl get pods              8x   est. ~2400 tok
  prisma migrate dev            5x   est. ~1500 tok

Total potential: ~8,700 tok ($0.02)
Tip: lean-ctx init --global`,
        },
      },
    ],
  },
  {
    id: 'monitoring',
    label: 'Monitoring & Stats',
    accent: 'green',
    description: 'Real-time session metrics, persistent stats, and a visual terminal dashboard.',
    tools: [
      {
        id: 'ctx_metrics',
        name: 'ctx_metrics',
        tagline: 'Real-time Session Statistics',
        savings: 'Monitoring',
        description: 'Session-wide statistics with tiktoken-measured token counts and USD cost estimates. Tracks cache hit rates, per-tool savings, and projected costs.',
        example: {
          input: 'ctx_metrics',
          output: `§metrics
════════════════════════════════════════
files:12 reads:34 hits:22 (65%)
tok: 28.5K→4.1K | saved:24.3K (85.5%)
cost: $0.4270→$0.0620 | -$0.3650

tool            n    orig   saved    %
────────────────────────────────────────
ctx_read       18   22.1K   19.2K  87%
ctx_shell       8    4.2K    3.1K  74%
ctx_search      5    1.8K    1.4K  78%

∴ session savings (incl. thinking): $0.912`,
        },
      },
    ],
  },
  {
    id: 'session',
    label: 'Session Continuity (CCP)',
    accent: 'green',
    description: 'New in v2.0.0. Cross-session memory via the Context Continuity Protocol. Persists task, findings, and decisions across chats and context compactions.',
    tools: [
      {
        id: 'ctx_session',
        name: 'ctx_session',
        tagline: 'Cross-Session Memory',
        savings: 'Cold-start elimination',
        description: 'Persists session state (task, findings, decisions, files touched) across chats, context compactions, and IDE restarts. Supports actions: status, load, save, task, finding, decision, reset, list, cleanup.',
        example: {
          input: 'ctx_session action=status',
          output: `SESSION v3 (started 2h ago)
Task: Implement auth module
Findings: 4 | Decisions: 2 | Files: 8
Next: Add JWT validation middleware

LITM position: begin_block (task+decisions)
              end_block (findings+progress)`,
        },
      },
      {
        id: 'ctx_wrapped',
        name: 'ctx_wrapped',
        tagline: 'Shareable Savings Report',
        savings: 'Viral reporting',
        description: 'Generates a "Spotify Wrapped"-style savings report with total tokens saved, compression rate, top commands, and cost estimates. Share your efficiency wins.',
        example: {
          input: 'ctx_wrapped',
          output: `LEAN-CTX WRAPPED
Total saved: 1.7M tokens ($4.25)
Compression: 76.8% avg
Top: curl (728K), git commit (375K)
Session: 520 commands over 2 days`,
        },
      },
    ],
  },
  {
    id: 'cli',
    label: 'CLI Commands',
    accent: 'green',
    description: 'One-command setup and a visual terminal dashboard for lifetime savings tracking.',
    tools: [
      {
        id: 'cli_init',
        name: 'lean-ctx init',
        tagline: 'One-Command Setup',
        savings: 'Auto-setup',
        description: 'Initialize lean-ctx locally or globally. With --global, auto-installs 23 shell aliases (Bash/Zsh/Fish) or PowerShell functions for git, npm, cargo, docker, kubectl, gh, pip, ruff, and more. Works on macOS, Linux, and Windows.',
        example: {
          input: 'lean-ctx init --global',
          output: `Installing lean-ctx shell aliases...
Added to ~/.zshrc (or PowerShell profile on Windows):
  alias git='lean-ctx -c git'
  alias npm='lean-ctx -c npm'
  alias cargo='lean-ctx -c cargo'
  ... (23 aliases total)
Done! Restart your shell.`,
        },
      },
      {
        id: 'cli_gain',
        name: 'lean-ctx gain',
        tagline: 'Visual Terminal Dashboard',
        savings: 'Lifetime stats',
        description: 'ANSI colors, Unicode block-chart bars, sparkline trends, and USD cost estimates. Also supports --graph, --daily, and --json.',
        example: {
          input: 'lean-ctx gain',
          output: '',
        },
      },
    ],
  },
];

const allTools = categories.flatMap(c => c.tools);
---

<BaseLayout title="Features — LeanCTX" description="The Cognitive Filter: 21 MCP tools, 90+ CLI compression patterns. AST signatures, delta-loading, entropy filtering, session caching, Token Dense Dialect. Maximum information density per token.">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 pt-16 sm:pt-28 pb-12 sm:pb-20">

    <div class="max-w-2xl mb-10 sm:mb-14">
      <p class="text-[11px] font-medium uppercase tracking-[0.2em] text-accent mb-3">The Cognitive Filter</p>
      <h1 class="font-display text-3xl sm:text-[2.75rem] lg:text-[3.25rem] font-bold tracking-tight leading-[1.1] text-text-bright mb-4">Every tool, <span class="gradient-text-green">maximum signal.</span></h1>
      <p class="text-sm sm:text-base text-muted leading-relaxed mb-4">
        21 MCP tools + a full CLI. Each one strips noise and delivers only the logic nodes your LLM needs.
      </p>
      <p class="text-xs text-muted font-mono">
        <span class="text-accent">21</span> MCP tools
        <span class="mx-2 text-border-light">/</span>
        <span class="text-accent">90+</span> CLI patterns
        <span class="mx-2 text-border-light">/</span>
        <span class="text-accent">14</span> languages
      </p>
    </div>

    <nav class="mb-10 sm:mb-14 overflow-x-auto scrollbar-hide -mx-4 px-4 sm:mx-0 sm:px-0">
      <div class="flex sm:flex-wrap gap-1 sm:gap-1.5">
        {allTools.map(tool => (
          <a href={`#${tool.id}`} class="shrink-0 px-3 py-1.5 text-[11px] font-mono font-medium rounded-md text-muted hover:text-accent hover:bg-white/[0.03] transition-all whitespace-nowrap">
            {tool.name}
          </a>
        ))}
      </div>
    </nav>

    <div class="space-y-14 sm:space-y-20">
      {categories.map((cat, catIdx) => (
        <section id={cat.id}>
          {catIdx > 0 && <div class="section-divider mb-10 sm:mb-14"></div>}

          <div class="mb-6 sm:mb-8">
            <h2 class="font-display text-lg sm:text-xl font-bold text-text-bright mb-1">{cat.label}</h2>
            <p class="text-[13px] text-muted">{cat.description}</p>
          </div>

          <div class="space-y-0">
            {cat.tools.map((tool, toolIdx) => (
              <article id={tool.id} class:list={['scroll-mt-20 py-6 sm:py-8 animate-entrance', toolIdx > 0 && 'border-t border-white/[0.06]']}>

                <div class="flex flex-wrap items-baseline gap-3 mb-3">
                  <h3 class="text-sm sm:text-base font-bold font-mono text-text-bright">{tool.name}</h3>
                  <span class="text-[13px] text-muted">{tool.tagline}</span>
                  <span class="ml-auto text-[11px] font-mono text-accent">{tool.savings}</span>
                </div>

                <div class="grid lg:grid-cols-2 gap-5 lg:gap-8">
                  <div>
                    <p class="text-sm text-muted leading-relaxed">{tool.description}</p>

                    {tool.modes && tool.modes.length > 0 && (
                      <div class="mt-5">
                        <p class="text-[11px] font-medium uppercase tracking-wider text-muted mb-3">Compression Modes</p>
                        <div class="grid grid-cols-2 sm:grid-cols-3 gap-2">
                          {tool.modes.map((mode) => (
                            <div class="rounded-lg border border-white/[0.06] bg-white/[0.015] px-3 py-2.5 hover:border-accent/20 hover:bg-accent/[0.02] transition-all duration-200">
                              <div class="flex items-center justify-between mb-1.5">
                                <code class="text-[11px] font-mono font-bold text-text-bright">{mode.name}</code>
                                <span class="text-[10px] font-mono text-accent font-semibold">{mode.savings}</span>
                              </div>
                              <p class="text-[11px] text-muted leading-snug">{mode.desc}</p>
                            </div>
                          ))}
                        </div>
                      </div>
                    )}
                  </div>

                  {tool.id === 'cli_gain' ? (
                    <div class="terminal-chrome font-mono text-[10px] sm:text-[12px] leading-[1.55]">
                      <div class="terminal-header flex items-center gap-1.5 px-4 py-2.5">
                        <div class="terminal-dot" style="background:#ef4444;width:7px;height:7px"></div>
                        <div class="terminal-dot" style="background:#eab308;width:7px;height:7px"></div>
                        <div class="terminal-dot" style="background:#34d399;width:7px;height:7px"></div>
                        <span class="text-muted text-[11px] ml-2">$ lean-ctx gain</span>
                        <span class="text-[9px] text-muted/40 ml-auto mr-2">real session data</span>
                      </div>
                      <div class="terminal-body px-4 py-3 overflow-x-auto">
                        <p><span class="text-white font-bold">◆ lean-ctx</span> <span class="text-[#999]">Token Savings Dashboard</span></p>
                        <p class="text-white/10">──────────────────────────────────────────────</p>
                        <p class="mt-1.5">
                          <span class="text-[#34d399] font-bold">1.7M</span><span class="text-[#999] text-[10px]"> saved</span>
                          <span class="ml-2 text-[#06b6d4] font-bold">76.8%</span><span class="text-[#999] text-[10px]"> rate</span>
                          <span class="ml-2 text-[#eab308] font-bold">520</span><span class="text-[#999] text-[10px]"> cmds</span>
                          <span class="ml-2 text-[#a855f7] font-bold">$4.25</span><span class="text-[#999] text-[10px]"> USD</span>
                        </p>
                        <p class="text-[#999] text-[10px] mt-0.5">Since 2026-03-23 <span class="text-[#34d399]">▁█</span></p>
                        <p class="mt-2 text-white font-semibold text-[11px]">Top Commands</p>
                        <p class="text-white/10">──────────────────────────────────────────────</p>
                        <p><span class="text-[#999]">curl       </span> 48x <span class="text-[#34d399]">████████████████████</span> <span class="text-[#34d399] font-bold">728.1K</span> <span class="text-[#999]">97%</span></p>
                        <p><span class="text-[#999]">git commit </span> 34x <span class="text-[#eab308]">██████████▎</span>          <span class="text-[#eab308] font-bold">375.2K</span> <span class="text-[#999]">50%</span></p>
                        <p><span class="text-[#999]">ctx_read   </span>103x <span class="text-[#a855f7]">█▌</span>                   <span class="text-[#a855f7] font-bold"> 59.1K</span> <span class="text-[#999]">38%</span></p>
                        <p class="text-[#999] text-[10px] mt-1">  ... +33 more</p>
                      </div>
                    </div>
                  ) : (
                    <div class="terminal-chrome font-mono text-[11px] sm:text-[13px] leading-relaxed">
                      <div class="terminal-header flex items-center gap-1.5 px-4 py-2.5">
                        <div class="terminal-dot" style="background:#ef4444;width:7px;height:7px"></div>
                        <div class="terminal-dot" style="background:#eab308;width:7px;height:7px"></div>
                        <div class="terminal-dot" style="background:#34d399;width:7px;height:7px"></div>
                        <span class="text-muted text-[11px] ml-2">$ {tool.example.input}</span>
                      </div>
                      <div class="terminal-body px-4 py-3 overflow-x-auto">
                        <pre class="text-text whitespace-pre-wrap">{tool.example.output}</pre>
                      </div>
                    </div>
                  )}
                </div>
              </article>
            ))}
          </div>
        </section>
      ))}
    </div>

    <div class="section-divider mt-14 sm:mt-20"></div>

    <section class="mt-14 sm:mt-20 max-w-3xl">
      <p class="text-[11px] font-medium uppercase tracking-[0.2em] text-accent-2 mb-3">Transparency</p>
      <h2 class="font-display text-xl sm:text-2xl font-bold tracking-tight text-text-bright leading-[1.15] mb-6">
        How We Measure Savings
      </h2>
      <div class="space-y-4 text-sm text-muted leading-relaxed">
        <p>
          All savings percentages on this site are measured <strong class="text-text-bright font-medium">per individual operation</strong>,
          not per session. The formula is: <code class="bg-surface-3 px-1.5 py-0.5 rounded-md text-accent-2 text-xs border border-border/40">(raw_tokens - compressed_tokens) / raw_tokens</code>.
        </p>
        <p>
          Token counts use <strong class="text-text-bright font-medium">tiktoken</strong> with the <code class="bg-surface-3 px-1.5 py-0.5 rounded-md text-accent-2 text-xs border border-border/40">o200k_base</code> encoding
          (used by GPT-4o, Claude, and most modern models). This gives consistent, reproducible measurements.
        </p>
        <div class="rounded-xl border border-white/[0.06] overflow-hidden">
          <table class="w-full text-xs">
            <thead>
              <tr class="bg-white/[0.02]">
                <th class="text-left px-4 py-2.5 text-muted font-medium">What we claim</th>
                <th class="text-left px-4 py-2.5 text-muted font-medium">What it means</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-white/[0.04]">
              <tr><td class="px-4 py-2">Up to 99%</td><td class="px-4 py-2">Cache re-reads: 13 tokens instead of full file content</td></tr>
              <tr><td class="px-4 py-2">85–95%</td><td class="px-4 py-2">First-read compression via <code>map</code> or <code>signatures</code> mode</td></tr>
              <tr><td class="px-4 py-2">60–90%</td><td class="px-4 py-2">Shell output compression via pattern matching</td></tr>
              <tr><td class="px-4 py-2">~65% re-reads</td><td class="px-4 py-2">Observed ratio in multi-step sessions where files are read repeatedly</td></tr>
            </tbody>
          </table>
        </div>
        <p>
          Ranges reflect variation across typical file sizes and command outputs. Session-wide savings
          depend on your usage pattern — typically <strong class="text-text-bright font-medium">60–85%</strong> when combining
          cached reads, compression modes, and shell hook.
        </p>
