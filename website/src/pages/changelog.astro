const majorReleases = releases.filter(r => ['Major', 'Launch', 'Genesis', 'Feature'].includes(r.tag));
const majorCount = majorReleases.length;
---

<BaseLayout title="Changelog — LeanCTX" description="Full version history of LeanCTX. Every feature, fix, and improvement — documented and transparent.">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 pt-16 sm:pt-28">

    <!-- Hero -->
    <div class="max-w-2xl mb-10 sm:mb-14">
      <p class="text-[11px] font-medium uppercase tracking-[0.2em] text-accent mb-3">Version History</p>
      <h1 class="font-display text-3xl sm:text-[2.75rem] lg:text-[3.25rem] font-bold tracking-tight leading-[1.1] text-text-bright mb-4">
        Built in the open,<br />
        <span class="gradient-text-green">shipped fast.</span>
      </h1>
      <p class="text-sm sm:text-base text-muted leading-relaxed mb-4">
        From first prototype to cross-platform Rust architecture in days. Every decision, every improvement — transparent and traceable.
      </p>
      <p class="text-xs text-muted font-mono">
        <span class="text-accent">{releases.length}</span> releases
        <span class="mx-2 text-border-light">/</span>
        <span class="text-accent">{majorCount}</span> major
        <span class="mx-2 text-border-light">/</span>
        current <span class="text-text-bright">v{releases[0].version}</span>
      </p>
    </div>

    <!-- Grid: Sidebar + Article -->
    <div class="lg:grid lg:grid-cols-[200px_1fr] lg:gap-14 pb-12 sm:pb-20">

      <!-- TOC Sidebar -->
      <aside class="hidden lg:block">
        <nav class="sticky top-24 space-y-0.5">
          <p class="text-xs font-semibold uppercase tracking-widest text-muted mb-4 font-display">Versions</p>
          {releases.map(r => (
            <a href={`#v${r.version}`} class:list={[
              'flex items-center gap-2 text-sm py-1.5 px-3 rounded-lg text-muted hover:text-text-bright hover:bg-surface-2 transition-all duration-200 changelog-toc-link',
            ]}>
              <span class:list={[
                'w-1.5 h-1.5 rounded-full shrink-0',
                ['Major', 'Launch', 'Genesis'].includes(r.tag) ? 'bg-accent' : ['Security', 'Bug Fix'].includes(r.tag) ? 'bg-danger' : ['Feature'].includes(r.tag) ? 'bg-accent/60' : 'bg-white/10'
              ]}></span>
              <span class="font-mono text-xs">v{r.version}</span>
            </a>
          ))}
        </nav>
      </aside>

      <!-- Article -->
      <article class="min-w-0 max-w-3xl">

        <!-- Releases -->
      {releases.map((release, i) => (
        <section id={`v${release.version}`} class:list={['scroll-mt-20 mb-8', i > 0 && 'pt-8 border-t border-border/20']}>

          <div class="flex flex-wrap items-baseline gap-2.5 mb-3">
            <h2 class="font-display text-base sm:text-lg font-semibold font-mono text-text-bright tracking-tight">v{release.version}</h2>
            <span class:list={['px-2 py-0.5 text-[10px] font-semibold rounded-full border', release.tagColor]}>{release.tag}</span>
            <span class="text-xs text-muted">{release.date}</span>
            {release.link && (
              <a href={release.link} target="_blank" rel="noopener" class="text-xs text-muted hover:text-accent transition-colors ml-auto">
                Release ↗
              </a>
            )}
          </div>

          <h3 class="text-sm sm:text-[15px] font-semibold font-display text-text-bright mb-4">{release.title}</h3>

          <ul class="space-y-2 mb-4">
            {release.highlights.map(h => (
              <li class="flex items-start gap-2.5 text-sm sm:text-[15px] text-muted leading-[1.8]">
                <span class="text-accent/60 mt-[0.35em] shrink-0 text-xs">—</span>
                <span set:html={h} />
              </li>
            ))}
          </ul>

          {release.details && (
            <p class="text-sm sm:text-[15px] text-muted/70 leading-[1.8]" set:html={release.details} />
          )}
        </section>
      ))}

      <!-- CTA -->
      <div class="pt-10 mt-4 border-t border-border/20">
        <p class="text-[11px] font-medium uppercase tracking-[0.2em] text-accent mb-4">The road ahead</p>
        <h2 class="font-display text-lg sm:text-xl font-semibold text-text-bright tracking-tight mb-4">We're just getting started.</h2>
        <p class="text-sm sm:text-[15px] text-muted leading-[1.8] mb-6">
          Follow the roadmap on GitHub or shape the future with us on Discord.
        </p>
