---
import BaseLayout from '../layouts/BaseLayout.astro';

const releases = [
  {
    version: '2.1.0',
    date: 'March 25, 2026',
    tag: 'Feature',
    tagColor: 'text-accent bg-accent/10 border-accent/20',
    title: 'Real Benchmark Engine — Project scanning, AST preservation scores, shareable reports',
    link: 'https://github.com/yvgude/lean-ctx/releases/tag/v2.1.0',
    highlights: [
      '<strong>Real project benchmark</strong>: Scans up to 50 files, measures actual token counts per compression mode with tiktoken',
      '<strong>AST-based preservation scoring</strong>: Verifies how many functions, exports, and imports survive compression using tree-sitter',
      '<strong>Latency tracking</strong>: Wall-clock timing per compression operation',
      '<strong>Session simulation</strong>: Models a 30-min coding session with real measurements (file reads, cache hits, shell commands)',
      '<strong>Three output formats</strong>: Terminal (ANSI), Markdown (shareable), JSON (machine-readable)',
      '<strong>MCP extension</strong>: <code>ctx_benchmark</code> now supports <code>action=project</code> for project-wide benchmarks',
    ],
    details: 'Replaces the estimation-based benchmark with a real measurement engine. Every number in the benchmark report comes from actual file processing — no estimates, no averages from historical stats.',
  },
  {
    version: '2.0.0',
    date: 'March 25, 2026',
    tag: 'Major',
    tagColor: 'text-accent bg-accent/10 border-accent/20',
